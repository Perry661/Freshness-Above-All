{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run FreshTracker",
      "type": "npm",
      "script": "start",
      "path": "",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(?!x)x$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "FreshTracker running at http://localhost:3000"
        }
      }
    }
  ]
}
